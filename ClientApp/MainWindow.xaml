<Window x:Class="ClientApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astronomical Processing System"
        Height="780"
        Width="1050"
        MinHeight="700"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <DockPanel x:Name="MainDock">

        <!-- Top Menu -->
        <Menu DockPanel.Dock="Top" x:Name="MainMenu">
            <MenuItem x:Name="menuLanguage" Header="Language">
                <MenuItem x:Name="menuEnglish" Header="English" Click="English_Click"/>
                <MenuItem x:Name="menuFrench" Header="French" Click="French_Click"/>
                <MenuItem x:Name="menuGerman" Header="German" Click="German_Click"/>
            </MenuItem>

            <MenuItem x:Name="menuTheme" Header="Theme">
                <MenuItem x:Name="menuLightTheme" Header="Light Theme" Click="LightTheme_Click"/>
                <MenuItem x:Name="menuDarkTheme" Header="Dark Theme" Click="DarkTheme_Click"/>
                <MenuItem x:Name="menuBlueTheme" Header="Blue Theme" Click="BlueTheme_Click"/>
            </MenuItem>

            <MenuItem x:Name="menuCustomise" Header="Customise">
                <MenuItem x:Name="menuBackgroundColour" Header="Change Background Colour" Click="BackgroundColour_Click"/>
                <MenuItem x:Name="menuLabelColour" Header="Change Label Colour" Click="LabelColour_Click"/>
                <MenuItem x:Name="menuTextBoxColour" Header="Change TextBox Colour" Click="TextBoxColour_Click"/>
                <MenuItem x:Name="menuFont" Header="Change Font" Click="Font_Click"/>
            </MenuItem>

            <MenuItem x:Name="menuAbout" Header="About">
                <MenuItem x:Name="menuAboutApp" Header="Application Info" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" x:Name="MainStatusBar">
            <TextBlock x:Name="txtStatusBar" Text="Ready"/>
        </StatusBar>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Title -->
                <TextBlock x:Name="txtMainTitle"
                           Text="Astronomical Processing System"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,20"/>

                <!-- Star Velocity -->
                <GroupBox x:Name="grpVelocity" Header="Star Velocity (Doppler Effect)" Margin="0,0,0,15" Padding="10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblObserved" Grid.Row="0" Grid.Column="0" Text="Observed Wavelength (nm):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtObserved" Grid.Row="0" Grid.Column="1" Height="28"/>

                        <Button x:Name="btnVelocity"
                                Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Calculate Velocity"
                                Height="32"
                                Click="BtnVelocity_Click"/>

                        <TextBlock x:Name="lblRest" Grid.Row="2" Grid.Column="0" Text="Rest Wavelength (nm):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtRest" Grid.Row="2" Grid.Column="1" Height="28"/>

                        <TextBlock x:Name="lblVelocity" Grid.Row="2" Grid.Column="3" Text="Radial Velocity (m/s):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtVelocity" Grid.Row="2" Grid.Column="4" Height="28" IsReadOnly="True" Margin="0,0,21,0"/>
                    </Grid>
                </GroupBox>

                <!-- Star Distance -->
                <GroupBox x:Name="grpDistance" Header="Star Distance (Parallax)" Margin="0,0,0,15" Padding="10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblParallax" Grid.Row="0" Grid.Column="0" Text="Parallax Angle (arcsec):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtParallax" Grid.Row="0" Grid.Column="1" Height="28"/>

                        <Button x:Name="btnDistance"
                                Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Calculate Distance"
                                Height="32"
                                Click="BtnDistance_Click"/>

                        <TextBlock x:Name="lblParsecs" Grid.Row="2" Grid.Column="3" Text="Distance (parsecs):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtParsecs" Grid.Row="2" Grid.Column="4" Height="28" IsReadOnly="True" Margin="0,0,43,0"/>

                        <TextBlock x:Name="lblLightYears" Grid.Row="4" Grid.Column="3" Text="Distance (light-years):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtLightYears" Grid.Row="4" Grid.Column="4" Height="28" IsReadOnly="True" Margin="0,0,43,0"/>

                        <TextBlock x:Name="lblKm" Grid.Row="2" Grid.Column="0" Text="Distance (km):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtKm" Grid.Row="2" Grid.Column="1" Height="28" IsReadOnly="True"/>
                    </Grid>
                </GroupBox>

                <!-- Temperature -->
                <GroupBox x:Name="grpTemperature" Header="Temperature Conversion (°C to K)" Margin="0,0,0,15" Padding="10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblCelsius" Grid.Row="0" Grid.Column="0" Text="Temperature (°C):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtCelsius" Grid.Row="0" Grid.Column="1" Height="28"/>

                        <Button x:Name="btnTemperature"
                                Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Convert to Kelvin"
                                Height="32"
                                Click="BtnTemp_Click"/>

                        <TextBlock x:Name="lblKelvin" Grid.Row="2" Grid.Column="3" Text="Temperature (K):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtKelvin" Grid.Row="2" Grid.Column="4" Height="28" IsReadOnly="True"/>
                    </Grid>
                </GroupBox>

                <!-- Black Hole -->
                <GroupBox x:Name="grpRadius" Header="Black Hole Event Horizon (Schwarzschild Radius)" Margin="0,0,0,15" Padding="10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblMass" Grid.Row="0" Grid.Column="0" Text="Black Hole Mass (kg):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtMass" Grid.Row="0" Grid.Column="1" Height="28"/>

                        <Button x:Name="btnRadius"
                                Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Calculate Radius"
                                Height="32"
                                Click="BtnRadius_Click"/>

                        <TextBlock x:Name="lblRadius" Grid.Row="2" Grid.Column="3" Text="Schwarzschild Radius (m):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtRadius" Grid.Row="2" Grid.Column="4" Height="28" IsReadOnly="True"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>